prefix=/data/data/com.diamon.civil/files/usr
exec_prefix=${prefix}
libdir=/data/data/com.diamon.civil/files/usr/lib
includedir=/data/data/com.diamon.civil/files/usr/include

Name: arpack
Description: Collection of Fortran77 subroutines designed to solve large scale eigenvalue problems
Version: 3.9.1
URL: https://github.com/opencollab/arpack-ng/
Libs: -L${libdir} -larpack
Libs.private: -lopenblas
Cflags: -I${includedir}/arpack
