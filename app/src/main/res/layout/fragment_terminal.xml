<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#1A1A1A">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FEA CORE TERMINAL"
            android:textColor="@color/terminal_green"
            android:textStyle="bold"
            android:paddingStart="8dp"/>
        <Button
            android:id="@+id/btnCopyLog"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COPY"
            android:textColor="@color/terminal_green"
            android:textSize="10sp"/>
        <Button
            android:id="@+id/btnExportReport"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EXPORT"
            android:textColor="@color/terminal_green"
            android:textSize="10sp"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">
        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="--- FEA Terminal Core ---\nType 'help' for commands.\n"
            android:textColor="@color/terminal_green"
            android:textSize="12sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0A0A0A"
        android:padding="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="fea@system:~$"
            android:textColor="@color/terminal_green"
            android:layout_marginEnd="8dp"/>
        <EditText
            android:id="@+id/etCommand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/terminal_green"
            android:background="@null"
            android:imeOptions="actionSend"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="14sp" />
        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/terminal_green" />
    </LinearLayout>
</LinearLayout>
