<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_black">

    <TextView
        android:id="@+id/tvTerminalHelp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FEA Advanced Terminal Console"
        android:textColor="@color/terminal_green"
        android:textSize="13sp"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:textStyle="bold" />

    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">
        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="--- FEA Terminal Core ---\n"
            android:textColor="@color/terminal_green"
            android:textSize="12sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0A0A0A"
        android:padding="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="fea@system:~$"
            android:textColor="@color/terminal_green"
            android:layout_marginEnd="8dp"/>
        <EditText
            android:id="@+id/etCommand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/terminal_green"
            android:background="@null"
            android:imeOptions="actionSend"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="14sp" />
        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/terminal_green" />
    </LinearLayout>
</LinearLayout>
