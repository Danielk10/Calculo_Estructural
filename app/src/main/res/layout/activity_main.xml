<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.MainActivity">

    <!-- Content Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/grey_background">

        <!-- Pantalla de carga (Overlay) -->
        <LinearLayout
            android:id="@+id/layoutLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/white"
            android:elevation="100dp"
            android:visibility="visible">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="@color/primaryColor"
                android:layout_marginBottom="24dp"/>

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminateTint="@color/primaryColor" />

            <TextView
                android:id="@+id/tvLoadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:textColor="@color/primaryDarkColor"
                android:textStyle="bold"
                android:textSize="16sp"
                android:text="Initializing FEA Engine..." />
        </LinearLayout>

        <!-- Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/primaryColor"
                app:title="Structural FEA"
                app:titleTextColor="@color/white" />
        </com.google.android.material.appbar.AppBarLayout>

        <FrameLayout
            android:id="@+id/content_frame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/appBarLayout"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- MODULE 1: STRUCTURAL ANALYSIS (PROTOTYPE) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/layoutStructural"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Structural Analysis"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/primaryDarkColor"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2D Frame &amp; Truss Solver"
                        android:textColor="@color/secondaryColor"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NODE DEFINITION"
                                android:textStyle="bold"
                                android:textColor="@color/primaryColor"
                                android:layout_marginBottom="8dp"/>

                            <EditText
                                android:id="@+id/etNodes"
                                android:layout_width="match_parent"
                                android:layout_height="100dp"
                                android:hint="Format: id, x, y (e.g. 1, 0, 0)"
                                android:gravity="top"
                                android:background="@drawable/edit_text_border"
                                android:padding="8dp"
                                android:fontFamily="monospace"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ELEMENT DEFINITION"
                                android:textStyle="bold"
                                android:textColor="@color/primaryColor"
                                android:layout_marginBottom="8dp"/>

                            <EditText
                                android:id="@+id/etElements"
                                android:layout_width="match_parent"
                                android:layout_height="100dp"
                                android:hint="Format: id, node1, node2 (e.g. 1, 1, 2)"
                                android:gravity="top"
                                android:background="@drawable/edit_text_border"
                                android:padding="8dp"
                                android:fontFamily="monospace"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSolveStructural"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="RUN 2D SOLVER"
                        app:cornerRadius="8dp"
                        android:layout_marginBottom="8dp"/>

                    <ProgressBar
                        android:id="@+id/pbStructural"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="true"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvStructuralResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="Output results will appear here."
                        android:background="#E0E0E0"
                        android:fontFamily="monospace"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <Button android:id="@+id/btnShowBMD" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BMD" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textSize="10sp"/>
                        <Button android:id="@+id/btnShowSFD" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SFD" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textSize="10sp"/>
                        <Button android:id="@+id/btnShowAFD" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="AFD" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textSize="10sp"/>
                        <Button android:id="@+id/btnHideDiagram" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="OFF" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textSize="10sp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnImportInp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="IMPORT .INP"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <LinearLayout
                android:id="@+id/containerStructural"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:visibility="gone">

                <com.diamon.civil.ui.FrameGLSurfaceView
                    android:id="@+id/frameGLView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.diamon.civil.ui.DiagramView
                    android:id="@+id/diagramView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- MODULE 2: 3D SOLID ANALYSIS (EXISTING) -->
            <LinearLayout
                android:id="@+id/layout3DSolid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayout3D"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white">
                    <com.google.android.material.tabs.TabItem android:text="PARAMETERS" />
                    <com.google.android.material.tabs.TabItem android:text="VIEWER 3D" />
                </com.google.android.material.tabs.TabLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.core.widget.NestedScrollView
                        android:id="@+id/layout3DParams"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="3D Beam Solid Analysis"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primaryDarkColor"
                                android:layout_marginBottom="16dp"/>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                app:cardElevation="2dp"
                                app:cardCornerRadius="12dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CAD OPERATIONS" android:textStyle="bold" android:textColor="@color/primaryColor" android:textSize="13sp" android:layout_marginBottom="12dp"/>
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">
                                        <Button android:id="@+id/btnCreateBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BOX" style="@style/Widget.MaterialComponents.Button.TextButton"/>
                                        <Button android:id="@+id/btnCreateCylinder" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="CYL" style="@style/Widget.MaterialComponents.Button.TextButton"/>
                                        <Button android:id="@+id/btnCreateSphere" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SPHERE" style="@style/Widget.MaterialComponents.Button.TextButton"/>
                                    </LinearLayout>
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:layout_marginTop="4dp">
                                        <Button android:id="@+id/btnFuse" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="FUSE" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="#E91E63"/>
                                        <Button android:id="@+id/btnCut" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="CUT" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="#E91E63"/>
                                        <Button android:id="@+id/btnIntersect" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="INT" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="#E91E63"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Reutilizamos las cards actuales -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                app:cardElevation="2dp"
                                app:cardCornerRadius="12dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/geometry_header" android:textStyle="bold" android:textColor="@color/primaryColor" android:textSize="13sp" android:layout_marginBottom="12dp"/>
                                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Total Span (m)" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
                                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etLength" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:text="10.0" />
                                    </com.google.android.material.textfield.TextInputLayout>
                                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Cross Section (W x H mm)" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
                                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSection" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="text" android:text="300x500" />
                                    </com.google.android.material.textfield.TextInputLayout>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                app:cardElevation="2dp"
                                app:cardCornerRadius="12dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/material_header" android:textStyle="bold" android:textColor="@color/primaryColor" android:textSize="13sp" android:layout_marginBottom="12dp"/>
                                    <Spinner android:id="@+id/spinnerMaterial" android:layout_width="match_parent" android:layout_height="48dp" android:entries="@array/material_options" />
                                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutModulus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Young's Modulus (MPa)" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
                                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etModulus" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:text="210000" />
                                    </com.google.android.material.textfield.TextInputLayout>
                                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Material Density (kg/m³)" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
                                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDensity" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:text="7850" />
                                    </com.google.android.material.textfield.TextInputLayout>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                app:cardElevation="2dp"
                                app:cardCornerRadius="12dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="20dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/loads_header" android:textStyle="bold" android:textColor="@color/primaryColor" android:textSize="13sp" android:layout_marginBottom="12dp"/>
                                    <Spinner android:id="@+id/spinnerAnalysisMode" android:layout_width="match_parent" android:layout_height="48dp" android:entries="@array/analysis_modes" />
                                    <Spinner android:id="@+id/spinnerSupport" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:entries="@array/support_options" />
                                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutPointLoad" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:hint="Point Load (kN)" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
                                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etLoad" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:text="0.0" />
                                    </com.google.android.material.textfield.TextInputLayout>
                                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutDistLoad" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Dist. Load (kN/m)" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
                                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDistLoad" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:text="10.0" />
                                    </com.google.android.material.textfield.TextInputLayout>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRunAnalysis"
                                android:layout_width="match_parent"
                                android:layout_height="64dp"
                                android:text="SOLVE &amp; GENERATE 3D"
                                android:textStyle="bold"
                                app:cornerRadius="16dp"
                                android:layout_marginBottom="8dp" />

                            <ProgressBar
                                android:id="@+id/pb3D"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:indeterminate="true"
                                android:visibility="gone"
                                android:layout_marginBottom="8dp" />

                            <!-- A1: CAD Pipeline button -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnImportCad"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:text="⬆ Import CAD (STL/STEP/IGES)"
                                android:textStyle="bold"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                app:cornerRadius="16dp"
                                android:layout_marginBottom="8dp" />

                            <!-- Mesh density slider -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mesh: Coarse"
                                    android:textSize="11sp"
                                    android:textColor="@color/secondaryColor"/>
                                <SeekBar
                                    android:id="@+id/seekbarMeshDensity"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="8dp"
                                    android:layout_marginEnd="8dp"
                                    android:max="4"
                                    android:progress="2" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Fine"
                                    android:textSize="11sp"
                                    android:textColor="@color/secondaryColor"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/results_header"
                                    android:textStyle="bold"
                                    android:textColor="@color/primaryDarkColor"
                                    android:textSize="14sp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnCopyResult"
                                    style="@style/Widget.MaterialComponents.Button.TextButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="COPY"
                                    app:icon="@android:drawable/ic_menu_edit" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnClearResult"
                                    style="@style/Widget.MaterialComponents.Button.TextButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CLEAR"
                                    app:icon="@android:drawable/ic_menu_delete" />
                            </LinearLayout>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="48dp"
                                app:cardElevation="1dp"
                                app:cardCornerRadius="12dp">
                                <TextView
                                    android:id="@+id/tvBasicResult"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:padding="16dp"
                                    android:text="Ready for computation."
                                    android:fontFamily="monospace"
                                    android:textSize="13sp" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>
                    </androidx.core.widget.NestedScrollView>

                    <androidx.compose.ui.platform.ComposeView
                        android:id="@+id/sceneViewComposeContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>

            <!-- TERMINAL (SHARED) -->
            <LinearLayout
                android:id="@+id/layoutConsole"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/terminal_black"
                android:visibility="gone">

                <ScrollView
                    android:id="@+id/scrollLog"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="--- Shared FEA Terminal Core ---\n"
                        android:textColor="@color/terminal_green"
                        android:textSize="12sp" />
                </ScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#0A0A0A"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="fea@system:~$"
                        android:textColor="@color/terminal_green"
                        android:layout_marginEnd="8dp"/>
                    <EditText
                        android:id="@+id/etCommand"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/terminal_green"
                        android:background="@null"
                        android:imeOptions="actionSend"
                        android:inputType="textNoSuggestions" />
                    <ImageButton
                        android:id="@+id/btnSend"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/terminal_green" />
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>

